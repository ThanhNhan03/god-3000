@model empMvc.Models.FRM_EMPViewModel
@{
    ViewData["Title"] = "Employee Management";
}

<h1>Employee Management</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="ID"></label>
        <input asp-for="ID" class="form-control" />
        <span asp-validation-for="ID" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Dept"></label>
        <input asp-for="Dept" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Salary"></label>
        <input asp-for="Salary" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Status"></label>
        <input asp-for="Status" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success" formaction="/FRM_EMP/Create">Create</button>
    <button type="submit" class="btn btn-primary" formaction="/FRM_EMP/Read">Read</button>
    <button type="submit" class="btn btn-warning" formaction="/FRM_EMP/Update">Update</button>
    <button type="submit" class="btn btn-danger" formaction="/FRM_EMP/Delete">Delete</button>
    <button type="submit" class="btn btn-secondary" formaction="/FRM_EMP/Clear">Clear</button>
</form>