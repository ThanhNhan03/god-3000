@model TestMigration.Models.SumViewModel

<!DOCTYPE html>
<html>
<head>
    <title>SUM-PROGRAM</title>
</head>
<body>
    <h1>SUM-PROGRAM</h1>

    <form method="post">
        <div>
            <label for="Num1">Enter first number:</label>
            <input type="number" id="Num1" name="Num1" value="@Model.Num1" required />
        </div>

        <div>
            <label for="Num2">Enter second number:</label>
            <input type="number" id="Num2" name="Num2" value="@Model.Num2" required />
        </div>

        <button type="submit">Calculate</button>
    </form>

    @if (ViewBag.Message != null)
    {
        <p>@ViewBag.Message</p>
    }
</body>
</html>