<!DOCTYPE html>
<html>
<head>
    <title>Employee Management</title>
</head>
<body>
    <h1>Employee List</h1>
    <a href="/EMPCRUD/Create">Create New Employee</a>
    <table>
        <thead>
            <tr>
                <th>Employee ID</th>
                <th>Name</th>
                <th>Department</th>
                <th>Salary</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in Model)
            {
                <tr>
                    <td>@employee.EmployeeId</td>
                    <td>@employee.EmployeeName</td>
                    <td>@employee.Department</td>
                    <td>@employee.Salary</td>
                    <td>@employee.Status</td>
                    <td>
                        <a href="/EMPCRUD/Edit/@employee.EmployeeId">Edit</a>
                        <a href="/EMPCRUD/Delete/@employee.EmployeeId">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>