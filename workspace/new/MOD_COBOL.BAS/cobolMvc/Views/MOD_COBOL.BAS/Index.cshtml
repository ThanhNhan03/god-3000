@model IEnumerable<cobolMvc.Models.EmployeeRecordViewModel>
@{
    ViewData["Title"] = "Employee Management";
}

<h1>Employee Management</h1>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Department</th>
            <th>Salary</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.EmpID</td>
                <td>@employee.EmpName</td>
                <td>@employee.EmpDept</td>
                <td>@employee.EmpSalary.ToString("F2")</td>
                <td>@(employee.EmpStatus == "A" ? "Active" : "Deleted")</td>
                <td>
                    <a asp-action="EditEmployee" asp-route-id="@employee.EmpID">Edit</a> |
                    <a asp-action="DeleteEmployee" asp-route-id="@employee.EmpID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="AddEmployee" class="btn btn-primary">Add Employee</a>